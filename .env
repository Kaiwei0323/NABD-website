# Frontend Environment Variables
# Copy this file to .env and update with your values

# API URL for backend server (used at build time; leave unset to use same origin /api when on https://inventecna.com)
# For production at https://inventecna.com (nginx proxies /api to backend):
VITE_API_URL=https://inventecna.com/api

# For local development:
# VITE_API_URL=http://localhost:3001/api
