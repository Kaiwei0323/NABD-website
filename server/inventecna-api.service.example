# Example systemd unit to run the API backend on port 3001.
# 1. Copy to systemd: sudo cp inventecna-api.service.example /etc/systemd/system/inventecna-api.service
# 2. Edit and set your real path: sudo nano /etc/systemd/system/inventecna-api.service
# 3. sudo systemctl daemon-reload && sudo systemctl enable inventecna-api && sudo systemctl start inventecna-api

[Unit]
Description=Inventecna API (Node backend for login/database)
After=network.target

[Service]
Type=simple
User=inventec
WorkingDirectory=/home/inventec/Documents/NABD-website/server
ExecStart=/usr/bin/node index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3001
Environment=HOST=0.0.0.0

[Install]
WantedBy=multi-user.target
